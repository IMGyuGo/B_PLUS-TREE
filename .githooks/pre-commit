#!/bin/bash
# pre-commit hook — 린트 + 테스트 통과해야만 커밋 허용
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "======= pre-commit gate ======="

# 1. 린트
echo "[1/2] lint..."
bash scripts/lint.sh
if [ $? -ne 0 ]; then
    echo ""
    echo "커밋 차단: 린트 실패. 위 오류를 수정 후 다시 커밋하세요."
    exit 1
fi

# 2. 테스트 (make 없으면 gcc 직접 실행)
echo "[2/2] test..."
if command -v make &>/dev/null; then
    make test
else
    gcc -std=c99 -Wall -Iinclude -o test_executor \
        tests/test_executor.c src/schema/schema.c src/executor/executor.c 2>&1 \
      && ./test_executor
fi

if [ $? -ne 0 ]; then
    echo ""
    echo "커밋 차단: 테스트 실패. 위 오류를 수정 후 다시 커밋하세요."
    exit 1
fi

echo "======= gate PASS — 커밋 허용 ======="
exit 0
